{
  "name": "interviewiq-backend",
  "version": "1.0.0",
  "description": "AI-Powered Technical Assessment & Interview Intelligence Platform Backend",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/server.js",
